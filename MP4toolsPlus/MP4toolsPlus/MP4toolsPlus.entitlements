<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Release entitlements for direct (Developer ID) distribution with a
	  BUNDLED ffmpeg/ffprobe.

	  App Sandbox is OFF for this distribution channel (a sandboxed app can't
	  spawn an arbitrary binary). Sandbox state is controlled by the
	  ENABLE_APP_SANDBOX build setting; leave it NO for the direct-DMG build.

	  Hardened Runtime IS on (required for notarization). The key below lets the
	  hardened runtime launch the bundled ffmpeg/ffprobe helper executables,
	  which are signed by you but are not part of the main binary.

	  To use this file: set the target's CODE_SIGN_ENTITLEMENTS build setting to
	  MP4toolsPlus/MP4toolsPlus.entitlements, or add Signing & Capabilities ▸
	  Hardened Runtime ▸ "Disable Library Validation", which writes this key.
	-->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
